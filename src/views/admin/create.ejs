<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novo Técnico - NivelSmart</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <img src="/logo.png" alt="NivelSmart" class="logo">
            <h1>Cadastrar Técnico</h1>
        </header>

        <div class="card">
            <form action="/admin/novo" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="id">ID do Técnico (Ex: NS-001)</label>
                    <input type="text" id="id" name="id" required placeholder="NS-XXX">
                </div>
                <div class="form-group">
                    <label for="nome">Nome Completo</label>
                    <input type="text" id="nome" name="nome" required>
                </div>
                <div class="form-group">
                    <label for="cargo">Cargo</label>
                    <input type="text" id="cargo" name="cargo" required>
                </div>
                <div class="form-group">
                    <label for="status">Status Inicial</label>
                    <select id="status" name="status">
                        <option value="ATIVO">ATIVO</option>
                        <option value="INATIVO">INATIVO</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="foto">Foto do Técnico</label>
                    <input type="file" id="foto" name="foto" accept="image/*">
                </div>
                
                <div style="margin-top: 25px; display: flex; gap: 10px;">
                    <button type="submit" class="btn btn-primary" style="flex: 1;">Salvar Técnico</button>
                    <a href="/admin" class="btn" style="background: #eee; flex: 1; text-align: center;">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
