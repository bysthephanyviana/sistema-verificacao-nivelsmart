<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novo Dispositivo - NivelSmart</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
    <div class="admin-container">
        <header style="margin-bottom: 2rem;">
            <a href="/admin/dispositivos" style="color: var(--primary); text-decoration: none; font-weight: 700;">← Voltar para lista</a>
            <h1 style="margin-top: 10px;">Cadastrar Novo Dispositivo</h1>
        </header>

        <div class="card">
            <form action="/admin/dispositivos/novo" method="POST">
                <div class="form-group">
                    <label for="id">ID Único (Ex: DISP-001)</label>
                    <input type="text" id="id" name="id" required placeholder="Ex: DISP-001">
                </div>

                <div class="form-group">
                    <label for="nome">Nome do Dispositivo</label>
                    <input type="text" id="nome" name="nome" required placeholder="Ex: Câmera IP Intelbras">
                </div>

                <div class="form-group">
                    <label for="id_service">ID Service</label>
                    <input type="text" id="id_service" name="id_service" required placeholder="Ex: SERV-12345">
                </div>

                <div class="form-group">
                    <label for="condominio">Nome do Condomínio</label>
                    <input type="text" id="condominio" name="condominio" required placeholder="Ex: Residencial Solar">
                </div>

                <div class="form-group">
                    <label for="quantidade_estoque">Quantidade em Estoque</label>
                    <input type="number" id="quantidade_estoque" name="quantidade_estoque" value="0" min="0">
                </div>

                <div class="form-group">
                    <label for="status">Status Inicial</label>
                    <select id="status" name="status">
                        <option value="ATIVO">ATIVO</option>
                        <option value="INATIVO">INATIVO</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Salvar Dispositivo</button>
            </form>
        </div>
    </div>
</body>
</html>
